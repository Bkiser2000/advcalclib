project Calc is

   for Source_Dirs use (".");
   for Object_Dir use "./obj";
   for Exec_Dir use "./bin";

   for Main use ("proj.adb", "calc.adb");

   package Compiler is
      for Switches ("Ada") use ("-gnat2012", "-gnatwa");
   end Compiler;

   package Linker is
      for Switches ("Ada") use (
         "./libadvcalc.so",
         "-lstdc++",
         "-Wl,-rpath,./"
      );
   end Linker;

end Calc;