30f23 num1{5|99F9}
30f38 num2{5|99F9}
35V13*Square_Root{5|99F9} 35>26
35f26 num1{5|99F9}
40V13*Cube_Root{5|99F9} 40>24
40f24 num1{5|99F9}
45V13*Factorial{5|99F9} 45>24
45f24 num1{5|99F9}
50V13*Natural_Log{5|99F9} 50>26
50f26 value{5|99F9}
57V13*Celsius_To_Fahrenheit{5|99F9} 57>36
57f36 c_temp{5|99F9}
62V13*Fahrenheit_To_Celsius{5|99F9} 62>36
62f36 f_temp{5|99F9}
67V13*Fahrenheit_To_Kelvin{5|99F9} 67>35
67f35 f_temp{5|99F9}
72V13*Celsius_To_Kelvin{5|99F9} 72>32
72f32 c_temp{5|99F9}
