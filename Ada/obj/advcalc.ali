V "GNAT Lib v14"
A -gnatA
A -gnat2012
A -gnatwa
A -mtune=generic
A -march=x86-64
P ZX

RN
RV NO_FLOATING_POINT
RV NO_IMPLEMENTATION_PRAGMAS

U advcalc%s		advcalc.ads		7412060f NE OO PK
W interfaces%s		interfac.ads		interfac.ali
W interfaces.c%s	i-c.adb			i-c.ali

D ada.ads		20250523110204 76789da1 ada%s
D a-unccon.ads		20250523110204 0e9b276f ada.unchecked_conversion%s
D advcalc.ads		20260323055900 ded110c1 advcalc%s
D interfac.ads		20250523110204 9111f9c1 interfaces%s
D i-c.ads		20250523110204 aac316ce interfaces.c%s
D system.ads		20250523110204 14286b0f system%s
D s-exctab.ads		20250523110204 91bef6ef system.exception_table%s
D s-parame.ads		20260202091358 a1aeab5c system.parameters%s
D s-stalib.ads		20250523110204 1c9580f6 system.standard_library%s
G a e
G c Z s s [add advcalc 8 13 none]
G c Z s s [subtract advcalc 13 13 none]
G c Z s s [multiply advcalc 18 13 none]
G c Z s s [divide advcalc 23 13 none]
G c Z s s [exponent advcalc 30 13 none]
G c Z s s [square_root advcalc 35 13 none]
G c Z s s [cube_root advcalc 40 13 none]
G c Z s s [factorial advcalc 45 13 none]
G c Z s s [natural_log advcalc 50 13 none]
G c Z s s [celsius_to_fahrenheit advcalc 57 13 none]
G c Z s s [fahrenheit_to_celsius advcalc 62 13 none]
G c Z s s [fahrenheit_to_kelvin advcalc 67 13 none]
G c Z s s [celsius_to_kelvin advcalc 72 13 none]
X 3 advcalc.ads
3K9*Advcalc 77l5 77e12
8V13*Add{5|99F9} 8>18 8>33
8f18 num1{5|99F9}
8f33 num2{5|99F9}
13V13*Subtract{5|99F9} 13>23 13>38
13f23 num1{5|99F9}
13f38 num2{5|99F9}
